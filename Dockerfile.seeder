# Self-host seeder loop (stonebridge fork addition — not upstream).
# Runs every seed script against the Redis REST proxy on a 30-min cycle,
# mirroring the SELF_HOSTING.md host-cron pattern as a single Railway service.
FROM node:22-alpine
WORKDIR /app
COPY . .
RUN npm ci --ignore-scripts --no-audit --no-fund
CMD ["sh", "-c", "while true; do sh scripts/run-seeders.sh; echo '[seeder] cycle done - sleeping 1800s'; sleep 1800; done"]
